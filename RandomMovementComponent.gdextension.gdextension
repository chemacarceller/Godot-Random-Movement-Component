[configuration]
    ; By setting entry_symbol = "RandomMovementComponent_init", you are telling Godot: "When you load this library, look for a C function named RandomMovementComponent_init to start everything up."
    entry_symbol = "RandomMovementComponent_init"
    compatibility_minimum = "4.1"

[libraries]
    windows.debug.x86_64 = "res://main/bin/RandomMovementComponent.windows.template_debug.dll"
    windows.release.x86_64 = "res://main/bin/RandomMovementComponent.windows.template_release.dll"
    linux.debug.x86_64 = "res://main/bin/RandomMovementComponent.linux.template_debug.so"
    linux.release.x86_64 = "res://main/bin/RandomMovementComponent.linux.template_release.so"
    macos.debug = ""
    macos.release = ""